# Kopíruj do .env a uprav dle potřeby
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

# SQLite databáze (relativní cesta k backend/)
DB_PATH=database/database.sqlite

# JWT tajný klíč pro admin API tokeny (změň v produkci!)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_TTL=3600

# CORS – povolený původ frontendu
CORS_ALLOWED_ORIGIN=http://localhost:5173

# Výchozí admin (použije se při seedování)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
